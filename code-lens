#!/usr/bin/env bash

set -u

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
RUNTIME_DIR="${TMPDIR:-/tmp}/codelens-review-${UID:-$(id -u)}"
LOG_DIR="$SCRIPT_DIR/logs"
API_PID_FILE="$RUNTIME_DIR/api.pid"
WORKER_PID_FILE="$RUNTIME_DIR/worker.pid"
FRONTEND_PID_FILE="$RUNTIME_DIR/frontend.pid"
API_PID=""
WORKER_PID=""
FRONTEND_PID=""
HOST=""

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

usage() {
  printf 'Usage: %s [start|stop|restart] [--host HOST]\n' "${0##*/}"
}

read_pid() {
  local pid_file=$1
  [ -f "$pid_file" ] || return 1
  local pid
  pid=$(<"$pid_file")
  case "$pid" in
    ''|*[!0-9]*) return 1 ;;
  esac
  printf '%s\n' "$pid"
}

is_running() {
  local pid=$1
  kill -0 "$pid" 2>/dev/null
}

remove_runtime_state() {
  rm -f "$API_PID_FILE" "$WORKER_PID_FILE" "$FRONTEND_PID_FILE"
  rmdir "$RUNTIME_DIR" 2>/dev/null || true
}

stop_pid_tree() {
  local pid=$1
  local child
  [ -n "$pid" ] || return 0
  is_running "$pid" || return 0

  # `uv run` remains as the recorded parent while it launches the Python
  # service. Stop descendants first so a restart cannot leave an orphan Worker.
  for child in $(pgrep -P "$pid" 2>/dev/null || true); do
    stop_pid_tree "$child"
  done
  kill "$pid" 2>/dev/null || true
  for _ in $(seq 1 50); do
    is_running "$pid" || return 0
    sleep 0.1
  done
  kill -KILL "$pid" 2>/dev/null || true
}

stop_process() {
  local pid_file=$1
  local pid
  pid=$(read_pid "$pid_file") || return 0
  if is_running "$pid"; then
    stop_pid_tree "$pid"
  fi
}

stop_pid() {
  local pid=$1
  stop_pid_tree "$pid"
}

remove_pid_file_if_owned() {
  local pid_file=$1
  local owned_pid=$2
  [ -n "$owned_pid" ] || return 0
  local recorded_pid
  recorded_pid=$(read_pid "$pid_file") || return 0
  [ "$recorded_pid" = "$owned_pid" ] && rm -f "$pid_file"
}

stop_services() {
  local was_running=false
  local pid_file
  for pid_file in "$API_PID_FILE" "$WORKER_PID_FILE" "$FRONTEND_PID_FILE"; do
    local pid
    pid=$(read_pid "$pid_file") || continue
    if is_running "$pid"; then
      was_running=true
    fi
    stop_process "$pid_file"
  done
  remove_runtime_state
  if [ "$was_running" = true ]; then
    printf 'CodeLens stopped.\n'
  else
    printf 'CodeLens is not running.\n'
  fi
}

cleanup() {
  trap - EXIT INT TERM
  stop_pid "$FRONTEND_PID"
  stop_pid "$WORKER_PID"
  stop_pid "$API_PID"
  remove_pid_file_if_owned "$FRONTEND_PID_FILE" "$FRONTEND_PID"
  remove_pid_file_if_owned "$WORKER_PID_FILE" "$WORKER_PID"
  remove_pid_file_if_owned "$API_PID_FILE" "$API_PID"
  rmdir "$RUNTIME_DIR" 2>/dev/null || true
}

wait_for_http() {
  local url=$1
  local process_pid=$2
  local name=$3
  for _ in $(seq 1 60); do
    if ! is_running "$process_pid"; then
      wait "$process_pid" 2>/dev/null || true
      fail "$name failed to start; inspect the output above"
    fi
    if curl --noproxy '*' --fail --silent --show-error --max-time 1 "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.5
  done
  fail "$name did not become ready within 30 seconds"
}

ensure_dependencies() {
  command -v uv >/dev/null 2>&1 || fail "uv is required: https://docs.astral.sh/uv/"
  command -v pnpm >/dev/null 2>&1 || fail "pnpm is required: https://pnpm.io/installation"
  command -v curl >/dev/null 2>&1 || fail "curl is required to verify service startup"

  printf '\n[1/3] Installing backend dependencies...\n'
  uv sync --project backend || fail "backend dependency installation failed"

  printf '\n[2/3] Installing frontend dependencies...\n'
  pnpm --dir frontend install || fail "frontend dependency installation failed"
}

start_services() {
  local pid_file
  for pid_file in "$API_PID_FILE" "$WORKER_PID_FILE" "$FRONTEND_PID_FILE"; do
    local pid
    pid=$(read_pid "$pid_file") || continue
    if is_running "$pid"; then
      fail "CodeLens is already running; use ./code-lens restart or ./code-lens stop"
    fi
  done
  remove_runtime_state

  ensure_dependencies
  umask 077
  mkdir -p "$RUNTIME_DIR" || fail "could not create runtime directory"

  printf '\n[3/3] Starting CodeLens...\n'
  mkdir -p "$LOG_DIR" || fail "could not create log directory"
  local host="${HOST:-127.0.0.1}"
  nohup uv run --project backend codelens-review api --host "$host" >>"$LOG_DIR/api.log" 2>&1 &
  API_PID=$!
  printf '%s\n' "$API_PID" >"$API_PID_FILE"
  nohup uv run --project backend codelens-review worker >>"$LOG_DIR/worker.log" 2>&1 &
  WORKER_PID=$!
  printf '%s\n' "$WORKER_PID" >"$WORKER_PID_FILE"
  nohup pnpm --dir frontend dev --host "$host" --strictPort >>"$LOG_DIR/frontend.log" 2>&1 &
  FRONTEND_PID=$!
  printf '%s\n' "$FRONTEND_PID" >"$FRONTEND_PID_FILE"

  wait_for_http "http://127.0.0.1:8765/api/health" "$API_PID" "Backend"
  wait_for_http "http://127.0.0.1:5173" "$FRONTEND_PID" "Frontend"

  printf '\nCodeLens is ready. Open these addresses:\n'
  printf '  Frontend:  http://%s:5173\n' "$host"
  printf '  Backend:   http://%s:8765\n' "$host"
  printf '  OpenAPI:   http://%s:8765/docs\n' "$host"
  printf '\nAll locally accessible Git repositories are allowed by default.\n'
  printf 'Choose a repository and configure model gateways in the Web UI.\n'
  printf 'Run ./code-lens stop to stop all services.\n\n'

  # The children are intentionally left running after readiness succeeds. PID
  # files are the lifecycle contract consumed by the stop and restart actions.
  trap - EXIT INT TERM
}

ACTION=${1:-start}
case "$ACTION" in
  start)
    shift || true
    while [ $# -gt 0 ]; do
      case "$1" in
        --host)
          [ $# -ge 2 ] || { usage >&2; exit 2; }
          HOST=$2; shift 2
          ;;
        *)
          usage >&2; exit 2
          ;;
      esac
    done
    cd "$SCRIPT_DIR"
    trap cleanup EXIT
    trap 'exit 130' INT TERM
    start_services
    ;;
  stop)
    [ "$#" -eq 1 ] || { usage >&2; exit 2; }
    stop_services
    ;;
  restart)
    shift || true
    while [ $# -gt 0 ]; do
      case "$1" in
        --host)
          [ $# -ge 2 ] || { usage >&2; exit 2; }
          HOST=$2; shift 2
          ;;
        *)
          usage >&2; exit 2
          ;;
      esac
    done
    stop_services
    cd "$SCRIPT_DIR"
    trap cleanup EXIT
    trap 'exit 130' INT TERM
    start_services
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
